{
	# Internal CA for LAN certs; don't force-redirect HTTP→HTTPS (both work).
	auto_https disable_redirects
	# Clients reaching the bare IP send no SNI — serve the IP's cert by default.
	default_sni 192.168.50.202
}

# HTTP (any host) → the app container over the shared "edge" network.
:80 {
	reverse_proxy dtot:3000
}

# HTTPS for the LAN names, served with Caddy's internal (self-signed) CA.
https://192.168.50.202, https://dtot.local, https://adastra.local {
	tls internal
	reverse_proxy dtot:3000
}

